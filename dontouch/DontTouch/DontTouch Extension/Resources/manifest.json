{
  "manifest_version": 3,
  "name": "Don't Touch Blocker",
  "version": "1.0",
  "description": "Detects and blurs NSFW/adult content using on-device AI. 100% private.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module",
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "scripts": ["contentBlocker.js"],
      "css": ["style.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["<all_urls>"],
      "scripts": ["content.js"],
      "css": [],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["icons/*"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
