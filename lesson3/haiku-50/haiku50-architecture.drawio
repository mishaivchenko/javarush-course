  <diagram name="Architecture">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== TIER 1: BROWSER ===== -->
        <mxCell id="t1" value="" style="swimlane;startSize=42;whiteSpace=wrap;html=1;fontStyle=1;fontSize=15;fillColor=#dae8fc;gradientColor=#eef4fb;gradientDirection=south;shadow=1;rounded=1;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="40" width="740" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="t1-title" value="&lt;b&gt;Browser&lt;/b&gt;&amp;nbsp;&amp;nbsp;—&amp;nbsp;&amp;nbsp;index.html (single-file frontend)" style="text;html=1;fontSize=14;fontColor=#333;fillColor=none;strokeColor=none;" vertex="1" parent="t1">
          <mxGeometry x="60" y="8" width="450" height="26" as="geometry"/>
